# 기본은 프로젝트 루트의 news.db (SQLite). 추후 교체 시 이 값만 바꾸면 됩니다.
# 예) PostgreSQL:  postgresql+psycopg://user:pass@localhost:5432/news
# 예) MySQL:       mysql+pymysql://user:pass@localhost:3306/news
DATABASE_URL=sqlite:///news.db

# 한 소스당 가져올 최대 기사 수 (0 = 제한 없음)
MAX_ENTRIES_PER_SOURCE=50

# 요청 타임아웃(초)
HTTP_TIMEOUT=15
