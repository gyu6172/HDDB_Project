# 팀 공용 Supabase DB (Session pooler)
# 비밀번호의 특수문자는 URL 인코딩 필요 (!=%21, ^=%5E, @=%40 등)
# 실제 비밀번호는 팀 채널에서 별도 공유받아 [PASSWORD] 자리를 채워서 사용하세요.
DATABASE_URL=postgresql://postgres.qtowsnliucvptzzmkwul:[PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres
PORT=8000
GEMINI_API_KEY=
SEARCH_THRESHOLD=0.3
# 검색 시 반환할 유사도 상위 결과 개수 (프론트가 이 안에서 필터/카운트/페이지네이션)
SEARCH_TOP_K=100
# 크롤링 후 요약·임베딩 자동 실행 여부 (크롤러 단독 테스트 시 false로 설정)
ENABLE_AI_PIPELINE=true
# CORS 허용 origin (쉼표 구분). 기본값은 로컬 프론트. prod 도메인은 여기에 추가.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
